{
  "name": "ps-local",
  "version": "0.1.0",
  "private": false,
  "engines": { "node": ">=22.6.0" },
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "cd showdown-ui && npm run dev",
    "start:legacy": "cd app && npx electron .",
    "start:local": "cd app && PS_SERVER=local npx electron .",
    "update-upstream": "node scripts/update-upstream.js",
    "apply-overlay": "node scripts/apply-overlay.js",
    "build:ability-desc": "node scripts/build-ability-descriptions.js",
    "test": "cd helper && node --test",
    "test:smoke": "node helper/test/smoke.mjs",
    "lint": "eslint .",
    "typecheck:ui": "cd showdown-ui && npm run typecheck",
    "setup:ui": "cd showdown-ui && npm install",
    "build:ui": "cd showdown-ui && npm run build",
    "dist:ui": "cd showdown-ui && npm run dist",
    "dist:ui:linux": "cd showdown-ui && npm run dist:linux",
    "dist:ui:win": "cd showdown-ui && npm run dist:win",
    "dist:ui:mac": "cd showdown-ui && npm run dist:mac"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
